{
  "info": {
    "_postman_id": "bfhl-api-collection-rajni",
    "name": "Bajaj Finserv Health API (BFHL) - Rajni Kumawat",
    "description": "Postman Collection for the Bajaj Finserv API round. Built by Rajni Kumawat (0827CI231106).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Process Data (Success)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": [\"a\", \"1\", \"334\", \"4\", \"R\", \"$\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/bfhl",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "bfhl"
          ]
        },
        "description": "Standard POST request to /bfhl processing the sample array of numbers, alphabets, and special characters."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"is_success is true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.is_success).to.eql(true);",
              "});",
              "",
              "pm.test(\"User ID format is correct\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.user_id).to.eql(\"rajni_kumawat_17092003\");",
              "});",
              "",
              "pm.test(\"Verify odd, even, alphabets extraction\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.odd_numbers).to.include(\"1\");",
              "    pm.expect(jsonData.even_numbers).to.include(\"334\", \"4\");",
              "    pm.expect(jsonData.alphabets).to.include(\"A\", \"R\");",
              "    pm.expect(jsonData.special_characters).to.include(\"$\");",
              "});",
              "",
              "pm.test(\"Verify calculation fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.sum).to.eql(339);",
              "    pm.expect(jsonData.concat_string).to.eql(\"Ra\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Process Data (Mixed and Multi-char)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": [\"12a\", \"a$1\", \"XYZ\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/bfhl",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "bfhl"
          ]
        },
        "description": "Tests handling of mixed strings (12a, a$1) and multi-character alphabets (XYZ)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"is_success is true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.is_success).to.eql(true);",
              "});",
              "",
              "pm.test(\"Verify sum and lists for mixed items\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.sum).to.eql(13);",
              "    pm.expect(jsonData.odd_numbers).to.include(\"1\");",
              "    pm.expect(jsonData.even_numbers).to.include(\"12\");",
              "    pm.expect(jsonData.alphabets).to.include(\"A\", \"XYZ\");",
              "    pm.expect(jsonData.special_characters).to.include(\"$\");",
              "    pm.expect(jsonData.concat_string).to.eql(\"ZyXaA\");",
              "});"
            ]
          }
        }
      ]
    },
