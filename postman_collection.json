    {
      "name": "Process Data (Empty payload)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"data\": []\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/bfhl",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "bfhl"
          ]
        },
        "description": "Tests POST endpoint behavior when given an empty data list."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"is_success is true and lists are empty\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.is_success).to.eql(true);",
              "    pm.expect(jsonData.odd_numbers).to.be.an('array').that.is.empty;",
              "    pm.expect(jsonData.even_numbers).to.be.an('array').that.is.empty;",
              "    pm.expect(jsonData.alphabets).to.be.an('array').that.is.empty;",
              "    pm.expect(jsonData.special_characters).to.be.an('array').that.is.empty;",
              "    pm.expect(jsonData.sum).to.eql(0);",
              "    pm.expect(jsonData.concat_string).to.eql(\"\");",
              "});"
            ]
          }
        }
      ]
    },
